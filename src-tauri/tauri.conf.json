{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "cp-companion",
  "version": "0.1.0",
  "identifier": "com.user.cp-companion",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CP Companion",
        "label": "widget",
        "width": 250,
        "height": 80,
        "resizable": false,
        "fullscreen": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": false,
        "skipTaskbar": true,
        "x": 50,
        "y": 50
      },
      {
        "title": "CP Companion - Main",
        "label": "main",
        "width": 900,
        "height": 600,
        "visible": false,
        "decorations": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
